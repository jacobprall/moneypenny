---
import Base from "../../layouts/Base.astro";
import { getCollection, type CollectionEntry } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) =>
    b.data.date.getTime() - a.data.date.getTime()
);

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<Base title="Blog — Moneypenny" description="Updates, deep dives, and thoughts on AI agents from the Moneypenny team.">
  <nav
    class="fixed top-0 z-50 w-full border-b border-zinc-800/50 bg-[#09090b]/80 backdrop-blur-xl"
  >
    <div class="mx-auto flex h-14 max-w-5xl items-center justify-between px-6">
      <a href="/" class="text-[15px] font-semibold tracking-tight">moneypenny</a>
      <div class="flex items-center gap-5">
        <a
          href="/blog/"
          class="text-[13px] text-zinc-50 transition-colors"
          >Blog</a
        >
        <a
          href="https://github.com/jacobprall/moneypenny"
          class="text-[13px] text-zinc-400 transition-colors hover:text-zinc-50"
          >GitHub</a
        >
      </div>
    </div>
  </nav>

  <main class="mx-auto max-w-2xl px-6 pt-32 pb-24">
    <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">Blog</h1>
    <p class="mt-3 text-[15px] text-zinc-400">
      Updates, deep dives, and thoughts on AI agents.
    </p>

    <div class="mt-12 space-y-10">
      {posts.map((post: CollectionEntry<"blog">) => (
        <article>
          <a href={`/blog/${post.id}/`} class="group block">
            <time class="text-[13px] text-zinc-500" datetime={post.data.date.toISOString()}>
              {formatDate(post.data.date)}
            </time>
            <h2 class="mt-1 text-xl font-semibold tracking-tight group-hover:text-zinc-300 transition-colors">
              {post.data.title}
            </h2>
            <p class="mt-2 text-[15px] leading-relaxed text-zinc-400">
              {post.data.description}
            </p>
          </a>
        </article>
      ))}
    </div>

    {posts.length === 0 && (
      <p class="mt-12 text-zinc-500">No posts yet. Check back soon.</p>
    )}
  </main>

  <footer class="border-t border-zinc-800/50 py-8">
    <div class="mx-auto flex max-w-5xl flex-col items-center justify-between gap-4 px-6 sm:flex-row">
      <p class="text-[13px] text-zinc-500">
        &copy; {new Date().getFullYear()} Moneypenny
      </p>
      <div class="flex gap-5">
        <a href="/blog/" class="text-[13px] text-zinc-500 transition-colors hover:text-zinc-300">Blog</a>
        <a href="https://github.com/jacobprall/moneypenny" class="text-[13px] text-zinc-500 transition-colors hover:text-zinc-300">GitHub</a>
      </div>
    </div>
  </footer>
</Base>
