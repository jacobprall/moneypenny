---
import Base from "../layouts/Base.astro";

const capabilities = [
  {
    title: "Persistent Memory",
    description:
      "Facts extracted after every turn, graph-linked, compressed to three tiers. Confidence grows on re-extraction. Stale knowledge decays. 500 facts fit in ~2K tokens.",
  },
  {
    title: "Policy Engine",
    description:
      "Every operation checked against policy before execution — static rules, behavioral limits, rate controls, time windows. Denials become context, not crashes.",
  },
  {
    title: "Hybrid Retrieval",
    description:
      "Semantic + full-text search across four stores, fused with Reciprocal Rank Fusion, diversified with MMR. One query, four sources, one coherent answer.",
  },
  {
    title: "Audit Trail",
    description:
      "Every action logged with full context — session, trace, the exact expression that triggered it. Queryable by the agent itself.",
  },
  {
    title: "Multi-Agent Sync",
    description:
      "CRDT-based knowledge sharing with scoped visibility — private, shared, or protected. No central server for local P2P.",
  },
  {
    title: "Runtime Agnostic",
    description:
      "Standalone agent with CLI, HTTP, Slack, Discord, Telegram. Or plug into any runtime as a sidecar via stdio, MCP, or HTTP.",
  },
];
---

<Base title="Moneypenny — The Intelligence Layer for AI Agents">
  <!-- Nav -->
  <nav
    class="fixed top-0 z-50 w-full border-b border-zinc-800/50 bg-[#09090b]/80 backdrop-blur-xl"
  >
    <div
      class="mx-auto flex h-14 max-w-5xl items-center justify-between px-6"
    >
      <a href="/" class="text-[15px] font-semibold tracking-tight"
        >moneypenny</a
      >
      <div class="flex items-center gap-5">
        <button
          id="theme-toggle"
          type="button"
          class="rounded-md border border-zinc-800 px-3 py-1.5 text-[13px] text-zinc-400 transition-colors hover:border-zinc-700 hover:text-zinc-50"
          aria-label="Cycle theme: dark, light, classified"
        >
          <span id="theme-toggle-label">Light</span>
        </button>
        <a
          href="/docs/"
          class="text-[13px] text-zinc-400 transition-colors hover:text-zinc-50"
          >Docs</a
        >
        <a
          href="https://github.com/jacobprall/moneypenny"
          class="text-[13px] text-zinc-400 transition-colors hover:text-zinc-50"
          >GitHub</a
        >
        <a
          href="#waitlist"
          class="rounded-md bg-zinc-50 px-3.5 py-1.5 text-[13px] font-medium text-zinc-950 transition-colors hover:bg-zinc-200"
          >Join Waitlist</a
        >
      </div>
    </div>
  </nav>

  <!-- ═══════════════ HERO ═══════════════ -->
  <section class="relative pt-32 pb-24 sm:pt-44 sm:pb-32">
    <div class="mx-auto max-w-3xl px-6 text-center">
      <div class="animate-fade-up">
      </div>

      <h1
        class="animate-fade-up animate-delay-100 text-4xl leading-[1.08] font-bold tracking-tight sm:text-6xl"
      >
        The intelligence layer<br />for AI agents
      </h1>

      <p
        class="animate-fade-up animate-delay-200 mx-auto mt-6 max-w-2xl text-[17px] leading-relaxed text-zinc-400"
      >
        Make every agent runtime smarter, safer, and stateful. Persistent
        memory, policy governance, and queryable audit — in a single SQLite
        file.
      </p>

      <div
        class="animate-fade-up animate-delay-300 mt-10 flex items-center justify-center gap-3"
      >
        <a
          href="/docs/quickstart/"
          class="rounded-md bg-zinc-50 px-5 py-2.5 text-sm font-medium text-zinc-950 transition-colors hover:bg-zinc-200"
          >Get Started</a
        >
        <a
          href="/docs/"
          class="rounded-md border border-zinc-800 px-5 py-2.5 text-sm font-medium text-zinc-400 transition-colors hover:border-zinc-700 hover:text-zinc-50"
          >Read the Docs</a
        >
      </div>
    </div>
  </section>

  <!-- ═══════════════ COPY PROMPT ═══════════════ -->
  <section class="relative pb-16 sm:pb-20">
    <div class="mx-auto max-w-2xl px-6">
      <p class="mb-3 text-center text-[13px] font-medium uppercase tracking-wider text-zinc-500">
        Paste this into your agent
      </p>
      <div
        id="prompt-box"
        class="group relative cursor-pointer overflow-hidden rounded-lg border border-zinc-800 bg-zinc-900/50 transition-colors hover:border-zinc-700"
      >
        <div class="flex items-center justify-between gap-4 px-5 py-4">
          <p class="font-mono text-[13px] leading-relaxed text-zinc-300">
            Visit https://github.com/jacobprall/moneypenny and set up the local mcp sidecar
          </p>
          <button
            id="copy-btn"
            class="flex shrink-0 items-center gap-1.5 rounded-md border border-zinc-700 px-3 py-1.5 text-[12px] font-medium text-zinc-400 transition-colors hover:border-zinc-600 hover:text-zinc-200"
          >
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
            </svg>
            <span id="copy-label">Copy</span>
          </button>
        </div>
      </div>
      <p class="mt-3 text-center text-[13px] text-zinc-500">
        Your agent will clone the repo, build the binary, start Moneypenny, and register it as an MCP server.
      </p>
    </div>
  </section>

  <!-- ═══════════════ TERMINAL ═══════════════ -->
  <section class="relative pb-24 sm:pb-32">
    <div class="mx-auto max-w-5xl px-6">
      <div class="grid gap-4 lg:grid-cols-3">

        <!-- Coding agent -->
        <div class="overflow-hidden rounded-lg border border-zinc-800 bg-zinc-900/50">
          <div class="flex items-center gap-2 border-b border-zinc-800 px-4 py-2.5">
            <span class="h-2 w-2 rounded-full bg-emerald-500/70"></span>
            <span class="text-[11px] font-medium text-zinc-500">coding-agent</span>
          </div>
          <div class="p-4 font-mono text-[12px] leading-relaxed">
            <p class="text-zinc-400">
              <span class="text-zinc-500">&gt;</span> Where did we land on the
              auth refactor? I started it two weeks ago.
            </p>
            <div class="mt-2 border-l-2 border-zinc-800 pl-3 text-zinc-500">
              Found 3 facts from your Feb 24-26 sessions. You chose passport.js
              over custom JWT for the OAuth flows. There's a migration plan in
              knowledge from the arch review, and PR #847 still has 2 open
              comments from Maya.
            </div>
            <p class="mt-3 text-zinc-400">
              <span class="text-zinc-500">&gt;</span> What did the docs say about
              the rate limit on that API?
            </p>
            <div class="mt-2 border-l-2 border-zinc-800 pl-3 text-zinc-500">
              From the ingested API spec: 120 req/min per client, 429 response
              includes Retry-After header. Your note from Mar 1 says the
              staging environment uses a 10x multiplier.
            </div>
          </div>
        </div>

        <!-- Project assistant -->
        <div class="overflow-hidden rounded-lg border border-zinc-800 bg-zinc-900/50">
          <div class="flex items-center gap-2 border-b border-zinc-800 px-4 py-2.5">
            <span class="h-2 w-2 rounded-full bg-blue-500/70"></span>
            <span class="text-[11px] font-medium text-zinc-500">project-assistant</span>
          </div>
          <div class="p-4 font-mono text-[12px] leading-relaxed">
            <p class="text-zinc-400">
              <span class="text-zinc-500">&gt;</span> Catch me up on Acme —
              haven't looked since Tuesday.
            </p>
            <div class="mt-2 border-l-2 border-zinc-800 pl-3 text-zinc-500">
              2 facts synced from design-agent since then: client approved the
              revised wireframes Thursday, launch moved to March 20. Your last
              note flagged the Stripe integration blocker — still unresolved.
            </div>
            <p class="mt-3 text-zinc-400">
              <span class="text-zinc-500">&gt;</span> What's the status across all
              my active projects?
            </p>
            <div class="mt-2 border-l-2 border-zinc-800 pl-3 text-zinc-500">
              3 active. Acme: blocked on Stripe (you, 5d). CloudCo: on track,
              deploy-agent merged the infra PR yesterday. Nova: pending client
              review since Mar 3, no new synced facts.
            </div>
          </div>
        </div>

        <!-- Ops / governance -->
        <div class="overflow-hidden rounded-lg border border-zinc-800 bg-zinc-900/50">
          <div class="flex items-center gap-2 border-b border-zinc-800 px-4 py-2.5">
            <span class="h-2 w-2 rounded-full bg-amber-500/70"></span>
            <span class="text-[11px] font-medium text-zinc-500">ops-admin</span>
          </div>
          <div class="p-4 font-mono text-[12px] leading-relaxed">
            <p class="text-zinc-400">
              <span class="text-zinc-500">&gt;</span> Push the schema migration
              to prod.
            </p>
            <div class="mt-2 border-l-2 border-red-900/50 pl-3 text-zinc-500">
              <span class="text-red-400/80">Denied:</span> Prod deploys blocked
              outside maintenance windows (Sat 2-6am UTC). Staging is clear —
              want me to run it there instead?
            </div>
            <p class="mt-3 text-zinc-400">
              <span class="text-zinc-500">&gt;</span> Who touched prod configs
              this week?
            </p>
            <div class="mt-2 border-l-2 border-zinc-800 pl-3 text-zinc-500">
              3 changes logged. ops-agent updated rate limits Mon, deploy-bot
              rolled back a feature flag Wed. Full trace for each in audit.
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════ PROBLEM / SOLUTION ═══════════════ -->
  <section class="relative py-24 sm:py-32">
    <div class="mx-auto max-w-5xl px-6">
      <div class="grid gap-16 lg:grid-cols-2 lg:gap-20">
        <!-- Problem -->
        <div>
          <p class="text-[13px] font-medium uppercase tracking-wider text-zinc-500">
            The problem
          </p>
          <h2 class="mt-3 text-2xl font-bold tracking-tight sm:text-3xl">
            AI agents forget everything
          </h2>
          <div class="mt-6 space-y-4 text-[15px] leading-relaxed text-zinc-400">
            <p>
              Every session starts from zero. Context is expensive, and
              everything the agent learned yesterday is gone today.
            </p>
            <p>
              Tool calls execute unchecked. There's no policy, no guardrails, no
              way to say "block destructive SQL" or "rate-limit shell access."
            </p>
            <p>
              When something goes wrong, there's no trail. You can't trace what
              the agent did, what it was denied, or why.
            </p>
            <p>
              Adding state means infrastructure — Postgres for storage, Redis
              for sessions, a vector database for retrieval, and an ops team to
              keep it all running.
            </p>
          </div>
        </div>

        <!-- Solution -->
        <div>
          <p class="text-[13px] font-medium uppercase tracking-wider text-zinc-500">
            The solution
          </p>
          <h2 class="mt-3 text-2xl font-bold tracking-tight sm:text-3xl">
            Moneypenny makes agents stateful
          </h2>
          <div class="mt-6 space-y-4 text-[15px] leading-relaxed text-zinc-400">
            <p>
              Every turn enriches a persistent knowledge graph — facts are
              extracted, linked, and compressed so today's session builds on
              yesterday's. One SQLite file per agent holds memory, policies,
              audit logs, and sync state.
            </p>
            <p>
              Operations are governed before they execute. Static rules,
              behavioral limits, rate controls — all evaluated in-process.
              Denials flow back as context the agent can reason about, not
              silent failures.
            </p>
            <p>
              Everything is auditable and queryable — by you and by the agent
              itself. No infrastructure beyond a single binary.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ CAPABILITIES ═══════════════ -->
  <section class="relative py-24 sm:py-32">
    <div class="mx-auto max-w-5xl px-6">
      <div
        class="grid gap-px overflow-hidden rounded-lg border border-zinc-800 bg-zinc-800 sm:grid-cols-2 lg:grid-cols-3"
      >
        {
          capabilities.map((f) => (
            <div class="bg-[#09090b] p-6">
              <h3 class="text-[15px] font-semibold">{f.title}</h3>
              <p class="mt-2 text-[13px] leading-relaxed text-zinc-400">
                {f.description}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ═══════════════ ARCHITECTURE ═══════════════ -->
  <section class="relative py-24 sm:py-32">
    <div class="mx-auto max-w-5xl px-6">
      <div class="grid items-start gap-12 lg:grid-cols-2 lg:gap-20">
        <div>
          <p class="text-[13px] font-medium uppercase tracking-wider text-zinc-500">
            Architecture
          </p>
          <h2 class="mt-3 text-2xl font-bold tracking-tight sm:text-3xl">
            Database as runtime
          </h2>
          <div class="mt-6 space-y-4 text-[15px] leading-relaxed text-zinc-400">
            <p>
              Everything lives in one SQLite file per agent — memory, documents,
              policies, audit trail, job schedules, sync state. Seven extensions
              are statically linked into one Rust binary: vector search,
              on-device inference, CRDT sync, JavaScript tools, and RAG.
            </p>
            <p>
              Agents interact through a single query language — one MCP tool
              that expresses every operation from memory search to policy
              creation. The agent learns the syntax from the tool description.
              No SDK, no tool discovery, no integration docs.
            </p>
            <p>
              Every surface — CLI, MCP sidecar, HTTP API, Slack, Discord — is a
              thin adapter. Business logic never leaves the database boundary.
            </p>
          </div>
        </div>

        <div>
          <p class="mb-3 text-[13px] font-medium uppercase tracking-wider text-zinc-500">
            What's inside
          </p>
          <div
            class="space-y-px overflow-hidden rounded-lg border border-zinc-800 bg-zinc-800"
          >
            {
              [
                ["SQLite + 7 extensions", "Vector search, FTS5, CRDT sync, on-device inference, JavaScript UDFs, RAG, JSON"],
                ["Rust binary", "Single statically-linked executable. No runtime dependencies, no containers, no JVM"],
                ["MCP native", "First-class Model Context Protocol support — stdio, HTTP, or sidecar. Works with any MCP client"],
                ["One query language", "Every platform operation expressed through one tool. The agent reads the grammar from the tool description"],
                ["Policy + audit", "Governance evaluated in-process before every operation. Full trace of every decision, queryable in real time"],
                ["CRDT sync", "Peer-to-peer knowledge sharing between agents with scoped visibility — no central coordination server"],
              ].map(([title, desc]) => (
                <div class="flex items-start gap-4 bg-[#09090b] px-5 py-3.5">
                  <div>
                    <p class="text-[14px] font-medium text-zinc-300">{title}</p>
                    <p class="text-[13px] text-zinc-500">{desc}</p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ WAITLIST ═══════════════ -->
  <section id="waitlist" class="relative py-24 sm:py-32">
    <div class="mx-auto max-w-md px-6 text-center">
      <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">
        Get early access
      </h2>
      <p class="mt-3 text-[15px] text-zinc-400">
        Subscribe to updates and be first to know when Moneypenny is ready.
      </p>

      <form id="waitlist-form" class="mt-8">
        <div class="flex gap-2">
          <input
            type="email"
            name="email"
            required
            placeholder="you@company.com"
            class="h-10 flex-1 rounded-md border border-zinc-800 bg-zinc-900 px-3.5 text-sm text-zinc-50 placeholder:text-zinc-500 focus:border-zinc-700 focus:outline-none focus:ring-1 focus:ring-zinc-700"
          />
          <button
            type="submit"
            class="h-10 shrink-0 rounded-md bg-zinc-50 px-4 text-sm font-medium text-zinc-950 transition-colors hover:bg-zinc-200 disabled:opacity-50"
          >
            Subscribe
          </button>
        </div>
        <p
          id="form-message"
          class="mt-3 hidden text-[13px] text-red-400/80"
        >
        </p>
      </form>

      <div id="form-success" class="mt-8 hidden">
        <p class="text-[15px] text-zinc-300">
          You're on the list. We'll be in touch.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════════ FOOTER ═══════════════ -->
  <footer class="border-t border-zinc-800/50 py-8">
    <div
      class="mx-auto flex max-w-5xl flex-col items-center justify-between gap-4 px-6 sm:flex-row"
    >
      <p class="text-[13px] text-zinc-500">
        &copy; {new Date().getFullYear()} Moneypenny
      </p>
      <div class="flex gap-5">
        <a
          href="/docs/"
          class="text-[13px] text-zinc-500 transition-colors hover:text-zinc-300"
          >Docs</a
        >
        <a
          href="https://github.com/jacobprall/moneypenny"
          class="text-[13px] text-zinc-500 transition-colors hover:text-zinc-300"
          >GitHub</a
        >
      </div>
    </div>
  </footer>
</Base>

<script>
  import { track } from "@vercel/analytics";

  const THEME_KEY = "moneypenny-theme";
  const THEMES = ["dark", "light", "confidential"] as const;
  type Theme = (typeof THEMES)[number];
  const NEXT_LABEL: Record<Theme, string> = {
    dark: "Light",
    light: "Classified",
    confidential: "Dark",
  };
  const root = document.documentElement;
  const themeToggle = document.getElementById("theme-toggle") as HTMLButtonElement;
  const themeToggleLabel = document.getElementById("theme-toggle-label") as HTMLElement;

  function applyTheme(theme: Theme) {
    root.classList.remove("theme-light", "theme-confidential");
    if (theme === "light") root.classList.add("theme-light");
    if (theme === "confidential") root.classList.add("theme-confidential");
    root.style.colorScheme = theme === "light" ? "light" : "dark";
    if (themeToggleLabel) themeToggleLabel.textContent = NEXT_LABEL[theme];
    root.dataset.theme = theme;
  }

  function currentTheme(): Theme {
    return (root.dataset.theme as Theme) || "dark";
  }

  try {
    const saved = localStorage.getItem(THEME_KEY) as Theme | null;
    applyTheme(THEMES.includes(saved as Theme) ? (saved as Theme) : "confidential");
  } catch {
    applyTheme("confidential");
  }

  themeToggle?.addEventListener("click", () => {
    const idx = THEMES.indexOf(currentTheme());
    const next = THEMES[(idx + 1) % THEMES.length];
    applyTheme(next);
    try {
      localStorage.setItem(THEME_KEY, next);
    } catch {}
  });

  const promptBox = document.getElementById("prompt-box") as HTMLElement;
  const copyBtn = document.getElementById("copy-btn") as HTMLButtonElement;
  const copyLabel = document.getElementById("copy-label") as HTMLElement;
  const promptText = "Visit https://github.com/jacobprall/moneypenny and set up the local sidecar";

  function copyPrompt() {
    navigator.clipboard.writeText(promptText).then(() => {
      copyLabel.textContent = "Copied!";
      copyBtn.classList.add("border-green-700", "text-green-400");
      track("copy_prompt");
      setTimeout(() => {
        copyLabel.textContent = "Copy";
        copyBtn.classList.remove("border-green-700", "text-green-400");
      }, 2000);
    });
  }

  copyBtn?.addEventListener("click", (e) => {
    e.stopPropagation();
    copyPrompt();
  });
  promptBox?.addEventListener("click", copyPrompt);

  const form = document.getElementById("waitlist-form") as HTMLFormElement;
  const message = document.getElementById("form-message") as HTMLElement;
  const success = document.getElementById("form-success") as HTMLElement;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const email = new FormData(form).get("email") as string;
    if (!email) return;

    const button = form.querySelector("button") as HTMLButtonElement;
    button.disabled = true;
    button.textContent = "...";

    try {
      track("waitlist_signup", { email });

      form.classList.add("hidden");
      success.classList.remove("hidden");
    } catch {
      button.disabled = false;
      button.textContent = "Subscribe";
      message.textContent = "Something went wrong. Please try again.";
      message.classList.remove("hidden");
    }
  });
</script>

<style is:global>
  :root {
    --mp-bg: #09090b;
    --mp-surface: rgba(24, 24, 27, 0.5);
    --mp-card: rgba(24, 24, 27, 0.3);
    --mp-border: rgba(39, 39, 42, 0.8);
    --mp-text: #fafafa;
    --mp-muted: #a1a1aa;
    --mp-subtle: #71717a;
    --mp-primary-bg: #fafafa;
    --mp-primary-text: #09090b;
    --mp-primary-hover: #e4e4e7;
  }

  html.theme-light {
    --mp-bg: #f8fafc;
    --mp-surface: rgba(255, 255, 255, 0.92);
    --mp-card: rgba(255, 255, 255, 0.96);
    --mp-border: rgba(212, 212, 216, 0.85);
    --mp-text: #111827;
    --mp-muted: #52525b;
    --mp-subtle: #71717a;
    --mp-primary-bg: #18181b;
    --mp-primary-text: #f8fafc;
    --mp-primary-hover: #27272a;
  }

  html.theme-confidential {
    --mp-bg: #c4a769;
    --mp-surface: rgba(210, 185, 130, 0.7);
    --mp-card: rgba(218, 195, 145, 0.55);
    --mp-border: rgba(140, 110, 60, 0.5);
    --mp-text: #1a1409;
    --mp-muted: #4a3d28;
    --mp-subtle: #6b5b3e;
    --mp-primary-bg: #9b1b1b;
    --mp-primary-text: #f5ead6;
    --mp-primary-hover: #7f1d1d;
  }

  html body {
    background: var(--mp-bg);
    color: var(--mp-text);
  }

  html [class*="bg-zinc-900"],
  html [class*="bg-[#09090b]"] {
    background-color: var(--mp-surface) !important;
  }

  html [class*="border-zinc-8"] {
    border-color: var(--mp-border) !important;
  }

  html [class*="text-zinc-50"] {
    color: var(--mp-text) !important;
  }

  html [class*="text-zinc-400"] {
    color: var(--mp-muted) !important;
  }

  html [class*="text-zinc-500"] {
    color: var(--mp-subtle) !important;
  }

  html [class*="bg-zinc-50"] {
    background-color: var(--mp-primary-bg) !important;
  }

  html [class*="text-zinc-950"] {
    color: var(--mp-primary-text) !important;
  }

  html [class*="hover:bg-zinc-200"]:hover {
    background-color: var(--mp-primary-hover) !important;
  }

  /* ── Confidential envelope theme extras ── */

  html.theme-confidential body {
    background-image:
      url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.06'/%3E%3C/svg%3E");
    background-size: 200px 200px;
  }

  html.theme-confidential nav {
    background-color: rgba(180, 155, 95, 0.85) !important;
