---
export const prerender = false;

import Base from "../layouts/Base.astro";

const user = Astro.locals.user!;
const supabase = Astro.locals.supabase;

const checkoutStatus = Astro.url.searchParams.get("checkout");

const { data: tenant } = await supabase
  .from("tenants")
  .select("*")
  .eq("user_id", user.id)
  .single();
---

<Base title="Dashboard — Moneypenny">
  <nav
    class="fixed top-0 z-50 w-full border-b border-zinc-800/50 bg-[#09090b]/80 backdrop-blur-xl"
  >
    <div
      class="mx-auto flex h-14 max-w-5xl items-center justify-between px-6"
    >
      <a href="/" class="text-[15px] font-semibold tracking-tight">moneypenny</a>
      <div class="flex items-center gap-5">
        <a href="/docs/" class="text-[13px] text-zinc-400 transition-colors hover:text-zinc-50">Docs</a>
        <span class="text-[13px] text-zinc-500">{user.email}</span>
        <a href="/auth/logout" class="text-[13px] text-zinc-400 transition-colors hover:text-zinc-50">Sign Out</a>
      </div>
    </div>
  </nav>

  <section class="pt-32 pb-24 sm:pt-40">
    <div class="mx-auto max-w-3xl px-6">
      <h1 class="text-2xl font-bold tracking-tight sm:text-3xl">Dashboard</h1>

      {checkoutStatus === "success" && (
        <div class="mt-6 rounded-md border border-emerald-900/50 bg-emerald-900/10 px-4 py-3 text-[13px] text-emerald-200/80">
          Payment successful. Your agent is being provisioned -- this usually takes under 60 seconds.
          Refresh this page to check status.
        </div>
      )}

      {!tenant || tenant.status === "pending" ? (
        <div class="mt-8 rounded-lg border border-zinc-800 bg-zinc-900/30 p-8">
          <h2 class="text-lg font-semibold">No active plan</h2>
          <p class="mt-2 text-[13px] text-zinc-400">
            Choose a plan to get your Moneypenny agent provisioned.
          </p>
          <a
            href="/pricing"
            class="mt-6 inline-block rounded-md bg-zinc-50 px-4 py-2.5 text-sm font-medium text-zinc-950 transition-colors hover:bg-zinc-200"
          >
            View Plans
          </a>
        </div>
      ) : tenant.status === "provision_failed" ? (
        <div class="mt-8 rounded-lg border border-red-900/50 bg-red-900/10 p-8">
          <h2 class="text-lg font-semibold text-red-300">Provisioning failed</h2>
          <p class="mt-2 text-[13px] text-zinc-400">
            Something went wrong setting up your agent. Please contact support.
          </p>
        </div>
      ) : (
        <div class="mt-8 space-y-6">
          <div class="rounded-lg border border-zinc-800 bg-zinc-900/30 p-6">
            <div class="flex items-center justify-between">
              <h2 class="text-lg font-semibold">Agent</h2>
              <span class:list={[
                "rounded-full px-2.5 py-0.5 text-[11px] font-medium uppercase tracking-wider",
                tenant.status === "active"
                  ? "bg-emerald-900/30 text-emerald-300"
                  : "bg-zinc-800 text-zinc-400",
              ]}>
                {tenant.status}
              </span>
            </div>

            <dl class="mt-6 space-y-4">
              <div>
                <dt class="text-[11px] font-medium uppercase tracking-wider text-zinc-500">Plan</dt>
                <dd class="mt-1 text-sm capitalize text-zinc-200">{tenant.plan}</dd>
              </div>

              <div>
                <dt class="text-[11px] font-medium uppercase tracking-wider text-zinc-500">Fly App</dt>
                <dd class="mt-1 font-mono text-sm text-zinc-200">
                  {tenant.fly_app_name ? (
                    <a
                      href={`https://${tenant.fly_app_name}.fly.dev`}
                      class="text-zinc-200 underline decoration-zinc-700 underline-offset-2 hover:decoration-zinc-500"
                      target="_blank"
                    >
                      {tenant.fly_app_name}.fly.dev
                    </a>
                  ) : (
                    <span class="text-zinc-500">Provisioning...</span>
                  )}
                </dd>
              </div>

              {tenant.http_api_key && (
                <div>
                  <dt class="text-[11px] font-medium uppercase tracking-wider text-zinc-500">API Key</dt>
                  <dd class="mt-1 flex items-center gap-2">
                    <code
                      id="api-key"
                      class="rounded bg-zinc-800/50 px-2 py-1 font-mono text-[13px] text-zinc-300"
                    >
                      {tenant.http_api_key.slice(0, 8)}...{tenant.http_api_key.slice(-4)}
                    </code>
                    <button
                      id="copy-key"
                      class="text-[12px] text-zinc-500 hover:text-zinc-300"
                      data-key={tenant.http_api_key}
                    >
                      Copy
                    </button>
                  </dd>
                </div>
              )}

              <div>
                <dt class="text-[11px] font-medium uppercase tracking-wider text-zinc-500">Region</dt>
                <dd class="mt-1 text-sm text-zinc-200">{tenant.fly_region}</dd>
              </div>
            </dl>
          </div>

          <div class="rounded-lg border border-zinc-800 bg-zinc-900/30 p-6">
            <h2 class="text-lg font-semibold">Set your LLM API key</h2>
            <p class="mt-2 text-[13px] leading-relaxed text-zinc-400">
              Moneypenny uses BYOK (bring your own key). Set your Anthropic or OpenAI key
              as a Fly secret so your agent can call the LLM:
            </p>
            <div class="mt-4 rounded-md bg-zinc-900 p-4 font-mono text-[13px] text-zinc-300">
              <p class="text-zinc-500"># Anthropic</p>
              <p>fly secrets set --app {tenant.fly_app_name} ANTHROPIC_API_KEY=sk-ant-...</p>
              <p class="mt-3 text-zinc-500"># OpenAI</p>
              <p>fly secrets set --app {tenant.fly_app_name} OPENAI_API_KEY=sk-...</p>
            </div>
          </div>

          <div class="rounded-lg border border-zinc-800 bg-zinc-900/30 p-6">
            <h2 class="text-lg font-semibold">Quick start</h2>
            <p class="mt-2 text-[13px] leading-relaxed text-zinc-400">
              Send a message to your agent:
            </p>
            <div class="mt-4 rounded-md bg-zinc-900 p-4 font-mono text-[13px] text-zinc-300">
              <p>curl -X POST https://{tenant.fly_app_name}.fly.dev/v1/message \</p>
              <p>&nbsp;&nbsp;-H "Authorization: Bearer YOUR_API_KEY" \</p>
              <p>&nbsp;&nbsp;-H "Content-Type: application/json" \</p>
              <p>&nbsp;&nbsp;-d '{JSON.stringify({ message: "Hello, Moneypenny" })}'</p>
            </div>
          </div>
        </div>
      )}
    </div>
  </section>
</Base>

<script>
  const copyBtn = document.getElementById("copy-key");
  copyBtn?.addEventListener("click", async () => {
    const key = (copyBtn as HTMLElement).dataset.key;
    if (key) {
      await navigator.clipboard.writeText(key);
      copyBtn.textContent = "Copied!";
      setTimeout(() => {
        copyBtn.textContent = "Copy";
      }, 2000);
    }
  });
</script>
