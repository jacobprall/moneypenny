{
  "name": "moneypenny",
  "private": true,
  "type": "module",
  "version": "0.3.0",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "bun apps/cli/src/main.ts start",
    "dev:ui": "cd apps/ui && pnpm dev",
    "serve": "bun apps/cli/src/main.ts serve",
    "chat": "bun apps/cli/src/main.ts chat",
    "index": "bun apps/cli/src/main.ts index",
    "embed": "bun apps/cli/src/main.ts embed",
    "detect": "bun apps/cli/src/main.ts detect",
    "migrate": "bun apps/cli/src/main.ts migrate",
    "build:ui": "cd apps/ui && pnpm build",
    "build": "pnpm run build:ui",
    "build:binary": "bun build --compile apps/cli/src/main.ts --outfile mp",
    "custodian": "bun apps/cli/src/main.ts custodian",
    "test": "bun test"
  },
  "bin": {
    "mp": "apps/cli/src/main.ts"
  },
  "devDependencies": {
    "bun-types": "^1.3.14"
  }
}
