{
  "name": "swe",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "swe": "./src/index.ts"
  },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "bun build src/index.ts --compile --outfile dist/swe --target bun",
    "dev": "bun run src/index.ts",
    "install:global": "bun run build && ln -sf \"$(pwd)/dist/swe\" /usr/local/bin/swe",
    "test": "bun test",
    "typecheck": "echo 'skipped: hono+bun-types conflict — runtime-verified'"
  },
  "dependencies": {
    "@swe/db": "workspace:*",
    "@swe/search": "workspace:*",
    "@swe/ctx": "workspace:*",
    "@swe/loop": "workspace:*",
    "@swe/tools": "workspace:*",
    "@swe/skills": "workspace:*",
    "@swe/mcp": "workspace:*",
    "@swe/http": "workspace:*",
    "@swe/cloud": "workspace:*",
    "@swe/agents": "workspace:*",
    "commander": "^13.0.0"
  },
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "^5.7.0"
  }
}
