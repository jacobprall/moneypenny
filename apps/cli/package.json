{
  "name": "moneypenny-cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "mp": "./src/index.ts"
  },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "bun build src/index.ts --outfile dist/mp --target bun",
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mp/db": "workspace:*",
    "@mp/search": "workspace:*",
    "@mp/ctx": "workspace:*",
    "@mp/loop": "workspace:*",
    "@mp/tools": "workspace:*",
    "@mp/skills": "workspace:*",
    "@mp/mcp": "workspace:*",
    "@mp/http": "workspace:*",
    "@mp/cloud": "workspace:*",
    "@mp/agents": "workspace:*",
    "commander": "^13.0.0"
  },
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "^5.7.0"
  }
}
